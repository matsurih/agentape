{
  "name": "agent-vcr",
  "version": "0.1.0",
  "description": "Record and replay AI agent tool calls, MCP calls, and HTTP requests. Test agents without spending tokens or hitting real APIs.",
  "type": "module",
  "license": "MIT",
  "bin": {
    "agent-vcr": "dist/cli.js"
  },
  "main": "dist/index.js",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && node scripts/copy-assets.mjs",
    "dev": "tsc -p tsconfig.json --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check src tests",
    "format": "biome format --write src tests",
    "ci:check": "biome ci src tests",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^22.7.5",
    "typescript": "^5.6.3",
    "vitest": "^2.1.3"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "agent",
    "ai",
    "vcr",
    "mcp",
    "mock",
    "testing",
    "record",
    "replay",
    "fixtures",
    "cassette"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/matsurih/agent-vcr.git"
  }
}
